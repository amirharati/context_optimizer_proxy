# API Keys for different providers (LiteLLM will auto-detect which one to use based on the model name in Cursor)
OPENROUTER_API_KEY=your_openrouter_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Compression Settings
MAX_MESSAGES_BEFORE_COMPRESS=10
KEEP_LAST_N_MESSAGES=4
CHEAP_MODEL_NAME=openrouter/google/gemini-flash-1.5
MAX_TOKENS_BEFORE_COMPRESS=16000

# Logging Settings
ENABLE_LOGGING=true
LOG_DIR=logs
DEBUG_BUFFER_SIZE=5 # Number of recent raw/compressed payloads to keep for the UI debugger

# Full session logging (WARNING: uses significant disk space!)
# When true: saves complete message history for each session to logs/sessions/
# When false (default): only saves metadata (token counts, model, timestamps)
# Turn ON when collecting training data for compression/routing analysis
# Turn OFF for production use to conserve disk space
ENABLE_FULL_SESSION_LOGGING=false

# A/B Testing Settings (optional - for integrated strategy testing)
# Strategies: none, noise_strip (more coming in later phases)
# Note: A/B test runner applies strategies before sending to proxy
# This setting is for testing strategies through live production traffic
AB_TEST_STRATEGY=none